<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watchtower</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { mono: ['JetBrains Mono', 'Fira Code', 'monospace'] }
          }
        }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-950 text-gray-100 font-mono min-h-screen">

    <!-- Sidebar -->
    <div class="flex min-h-screen">
      <aside class="w-56 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full">
        <div class="px-5 py-5 border-b border-gray-800">
          <div class="flex items-center gap-2">
            <span class="text-lg">🗼</span>
            <span class="text-white font-semibold tracking-wide">Watchtower</span>
          </div>
          <p class="text-gray-500 text-xs mt-1">Incident Dashboard</p>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-1">
          <%= link_to watchtower.incidents_path,
                class: "flex items-center gap-2 px-3 py-2 rounded text-sm text-gray-300
                        hover:bg-gray-800 hover:text-white transition-colors" do %>
            <span>⚡</span> Incidents
          <% end %>
        </nav>

        <div class="px-5 py-4 border-t border-gray-800">
          <p class="text-gray-600 text-xs">v<%= Watchtower::VERSION %></p>
        </div>
      </aside>

      <!-- Main content -->
      <main class="ml-56 flex-1 p-8">
        <% if notice.present? %>
          <div class="mb-4 px-4 py-3 rounded bg-green-900 border border-green-700 text-green-300 text-sm">
            <%= notice %>
          </div>
        <% end %>

        <% if alert.present? %>
          <div class="mb-4 px-4 py-3 rounded bg-red-900 border border-red-700 text-red-300 text-sm">
            <%= alert %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>

  </body>
</html>
