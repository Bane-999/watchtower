<!-- Header -->
<div class="mb-8">
  <h1 class="text-2xl font-semibold text-white">Incidents</h1>
  <p class="text-gray-500 text-sm mt-1">Unhandled exceptions captured by Watchtower</p>
</div>

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4">
    <p class="text-gray-500 text-xs uppercase tracking-wider">Open</p>
    <p class="text-3xl font-semibold text-white mt-1"><%= @open_count %></p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4">
    <p class="text-gray-500 text-xs uppercase tracking-wider">Resolved</p>
    <p class="text-3xl font-semibold text-white mt-1"><%= @resolved_count %></p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-lg px-5 py-4">
    <p class="text-gray-500 text-xs uppercase tracking-wider">Critical</p>
    <p class="text-3xl font-semibold text-red-400 mt-1"><%= @critical_count %></p>
  </div>
</div>

<!-- Filters -->
<div class="flex gap-3 mb-6">
  <%= link_to "All", watchtower.incidents_path,
        class: "px-3 py-1.5 rounded text-sm border #{ params[:status].blank? && params[:severity].blank? ?
          'bg-gray-700 border-gray-600 text-white' :
          'border-gray-700 text-gray-400 hover:text-white hover:bg-gray-800' }" %>

  <%= link_to "Open", watchtower.incidents_path(status: "open"),
        class: "px-3 py-1.5 rounded text-sm border #{ params[:status] == 'open' ?
          'bg-gray-700 border-gray-600 text-white' :
          'border-gray-700 text-gray-400 hover:text-white hover:bg-gray-800' }" %>

  <%= link_to "Resolved", watchtower.incidents_path(status: "resolved"),
        class: "px-3 py-1.5 rounded text-sm border #{ params[:status] == 'resolved' ?
          'bg-gray-700 border-gray-600 text-white' :
          'border-gray-700 text-gray-400 hover:text-white hover:bg-gray-800' }" %>

  <%= link_to "Critical", watchtower.incidents_path(severity: "critical"),
        class: "px-3 py-1.5 rounded text-sm border #{ params[:severity] == 'critical' ?
          'bg-red-900 border-red-700 text-red-300' :
          'border-gray-700 text-gray-400 hover:text-white hover:bg-gray-800' }" %>
</div>

<!-- Incidents table -->
<div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
  <% if @incidents.empty? %>
    <div class="px-6 py-16 text-center">
      <p class="text-gray-500 text-sm">No incidents found.</p>
      <p class="text-gray-600 text-xs mt-1">Your app is running clean. 🎉</p>
    </div>
  <% else %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-800">
          <th class="px-5 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Exception</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Severity</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Where</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">When</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-800">
        <% @incidents.each do |incident| %>
          <tr class="hover:bg-gray-800 transition-colors cursor-pointer"
              onclick="window.location='<%= watchtower.incident_path(incident) %>'">
            <td class="px-5 py-4">
              <p class="text-white font-medium"><%= incident.exception_class %></p>
              <p class="text-gray-500 text-xs mt-0.5 truncate max-w-sm"><%= incident.exception_message %></p>
            </td>
            <td class="px-5 py-4">
              <%= render "severity_badge", severity: incident.severity %>
            </td>
            <td class="px-5 py-4">
              <% if incident.resolved? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-green-900 text-green-300 border border-green-700">
                  resolved
                </span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-900 text-blue-300 border border-blue-700">
                  open
                </span>
              <% end %>
            </td>
            <td class="px-5 py-4 text-gray-400 text-xs">
              <% if incident.controller.present? %>
                <%= incident.controller %>#<%= incident.action %>
              <% else %>
                <span class="text-gray-600">—</span>
              <% end %>
            </td>
            <td class="px-5 py-4 text-gray-400 text-xs">
              <%= incident.occurred_at.strftime("%b %d, %H:%M") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Pagination -->
    <% if @incidents.respond_to?(:total_pages) && @incidents.total_pages > 1 %>
      <div class="px-5 py-4 border-t border-gray-800 flex items-center justify-between text-xs text-gray-500">
        <span>Page <%= @incidents.current_page %> of <%= @incidents.total_pages %></span>
        <div class="flex gap-2">
          <% if @incidents.prev_page %>
            <%= link_to "← Prev", watchtower.incidents_path(page: @incidents.prev_page, status: params[:status], severity: params[:severity]),
                  class: "px-3 py-1.5 rounded border border-gray-700 hover:text-white hover:bg-gray-800" %>
          <% end %>
          <% if @incidents.next_page %>
            <%= link_to "Next →", watchtower.incidents_path(page: @incidents.next_page, status: params[:status], severity: params[:severity]),
                  class: "px-3 py-1.5 rounded border border-gray-700 hover:text-white hover:bg-gray-800" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
