<!-- Header -->
<div class="mb-6 flex items-start justify-between">
  <div>
    <%= link_to "← Back to incidents", watchtower.incidents_path,
          class: "text-gray-500 text-sm hover:text-white mb-3 inline-block" %>
    <h1 class="text-xl font-semibold text-white"><%= @incident.exception_class %></h1>
    <p class="text-gray-400 text-sm mt-1"><%= @incident.exception_message %></p>
  </div>

  <div class="flex items-center gap-3 mt-6">
    <%= render "severity_badge", severity: @incident.severity %>

    <% unless @incident.resolved? %>
      <%= button_to "Resolve", watchtower.resolve_incident_path(@incident),
            method: :patch,
            class: "px-4 py-1.5 rounded text-sm bg-green-800 hover:bg-green-700
                    text-green-200 border border-green-700 transition-colors cursor-pointer" %>
    <% else %>
      <span class="px-3 py-1.5 whitespace-nowrap rounded text-xs bg-green-900 text-green-300 border border-green-700">
        ✓ Resolved <%= @incident.resolved_at&.strftime("%b %d, %H:%M") %>
      </span>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-3 gap-6">

  <!-- Left col: backtrace + metadata -->
  <div class="col-span-2 space-y-6">

    <!-- Backtrace -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h2 class="text-sm font-medium text-gray-300">Backtrace</h2>
      </div>
      <div class="px-5 py-4 overflow-x-auto">
        <% if @incident.backtrace.present? %>
          <% lines = @incident.backtrace.split("\n") %>
          <% app_lines, gem_lines = lines.partition { |l| l.include?("app/") } %>
          <div class="space-y-1">
            <% app_lines.first(5).each do |line| %>
              <p class="text-red-400 text-xs"><%= line.strip %></p>
            <% end %>
            <% if gem_lines.any? %>
              <details class="mt-2">
                <summary class="text-gray-600 text-xs cursor-pointer hover:text-gray-400">
                  Show <%= gem_lines.size %> gem lines
                </summary>
                <div class="mt-2 space-y-1">
                  <% gem_lines.first(20).each do |line| %>
                    <p class="text-gray-600 text-xs"><%= line.strip %></p>
                  <% end %>
                </div>
              </details>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-600 text-xs">No backtrace available.</p>
        <% end %>
      </div>
    </div>

    <!-- Metadata -->
    <% if @incident.metadata.present? %>
      <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-800">
          <h2 class="text-sm font-medium text-gray-300">Metadata</h2>
        </div>
        <div class="px-5 py-4">
          <pre class="text-xs text-green-400 overflow-x-auto"><%= JSON.pretty_generate(@incident.metadata) %></pre>
        </div>
      </div>
    <% end %>

    <!-- Params -->
    <% if @incident.params.present? %>
      <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-800">
          <h2 class="text-sm font-medium text-gray-300">Request Params</h2>
        </div>
        <div class="px-5 py-4">
          <pre class="text-xs text-green-400 overflow-x-auto"><%= JSON.pretty_generate(@incident.params) %></pre>
        </div>
      </div>
    <% end %>

  </div>

  <!-- Right col: request context + actor -->
  <div class="space-y-6">

    <!-- Request context -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h2 class="text-sm font-medium text-gray-300">Request</h2>
      </div>
      <div class="px-5 py-4 space-y-3 text-xs">
        <% [
          ["URL",        @incident.request_url],
          ["Method",     @incident.request_method],
          ["Controller", @incident.controller],
          ["Action",     @incident.action],
          ["IP",         @incident.ip_address],
          ["User Agent", @incident.user_agent],
        ].each do |label, value| %>
          <div>
            <p class="text-gray-600 uppercase tracking-wider text-xs"><%= label %></p>
            <p class="text-gray-300 mt-0.5 break-all"><%= value.presence || "—" %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Actor -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h2 class="text-sm font-medium text-gray-300">Actor</h2>
      </div>
      <div class="px-5 py-4 space-y-3 text-xs">
        <% [
          ["Type", @incident.actor_type],
          ["ID",   @incident.actor_id],
        ].each do |label, value| %>
          <div>
            <p class="text-gray-600 uppercase tracking-wider text-xs"><%= label %></p>
            <p class="text-gray-300 mt-0.5"><%= value.presence || "—" %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Timestamps -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h2 class="text-sm font-medium text-gray-300">Timestamps</h2>
      </div>
      <div class="px-5 py-4 space-y-3 text-xs">
        <% [
          ["Occurred",  @incident.occurred_at&.strftime("%b %d %Y, %H:%M:%S")],
          ["Resolved",  @incident.resolved_at&.strftime("%b %d %Y, %H:%M:%S")],
          ["Recorded",  @incident.created_at&.strftime("%b %d %Y, %H:%M:%S")],
        ].each do |label, value| %>
          <div>
            <p class="text-gray-600 uppercase tracking-wider text-xs"><%= label %></p>
            <p class="text-gray-300 mt-0.5"><%= value.presence || "—" %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Fingerprint -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h2 class="text-sm font-medium text-gray-300">Fingerprint</h2>
      </div>
      <div class="px-5 py-4">
        <p class="text-gray-500 text-xs break-all font-mono"><%= @incident.fingerprint %></p>
      </div>
    </div>

  </div>
</div>
