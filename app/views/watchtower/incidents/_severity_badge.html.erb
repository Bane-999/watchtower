<%
  colors = {
    "critical" => "bg-red-900 text-red-300 border border-red-700",
    "high"     => "bg-orange-900 text-orange-300 border border-orange-700",
    "medium"   => "bg-yellow-900 text-yellow-300 border border-yellow-700",
    "low"      => "bg-gray-800 text-gray-400 border border-gray-700"
  }
  css = colors.fetch(severity, colors["medium"])
%>
<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= css %>">
  <%= severity %>
</span>
